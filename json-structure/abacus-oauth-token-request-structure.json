{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/abacus/refs/heads/main/json-structure/abacus-oauth-token-request-structure.json",
  "name": "OAuthTokenRequest",
  "description": "OAuth 2.0 token request using client credentials",
  "type": "object",
  "properties": {
    "grant_type": {
      "type": "string",
      "description": "OAuth grant type",
      "enum": [
        "client_credentials"
      ],
      "example": "client_credentials"
    },
    "client_id": {
      "type": "string",
      "description": "OAuth client ID",
      "example": "example-client-id"
    },
    "client_secret": {
      "type": "string",
      "description": "OAuth client secret",
      "example": "example-client-secret"
    }
  },
  "required": [
    "grant_type",
    "client_id",
    "client_secret"
  ]
}